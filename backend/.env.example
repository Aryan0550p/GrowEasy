NODE_ENV=development
PORT=3001

# AI Provider: openai, gemini, or anthropic
# Set at least one API key below
AI_PROVIDER=gemini
AI_MODEL=gemini-1.5-flash

# API Keys
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Batch processing (records per AI call)
MAX_BATCH_SIZE=20
MAX_RETRIES=3
RETRY_DELAY_MS=1000

# CORS
FRONTEND_URL=http://localhost:3000
